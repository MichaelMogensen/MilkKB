<Window x:Class="DRDownloadWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DRDownloadWindow"
        mc:Ignorable="d"
        Title="DR Downloader" Height="600" Width="1000">
    <Window.CommandBindings>
        <CommandBinding Command="NavigationCommands.GoToPage" CanExecute="OnGoToPageCanExecute" Executed="OnGoToPageExecuted" />
    </Window.CommandBindings>
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">

            <Button DockPanel.Dock="Right" Command="NavigationCommands.GoToPage">
                <Image Source="C:\Users\micha\source\repos\MilkKB\DRDownloadWindow\Ressources\Png\go.png" Width="50" Height="50"/>
            </Button>
            <Separator DockPanel.Dock="Right" />

            <TextBox Name="urlTextBox" VerticalContentAlignment="Center" KeyUp="OnUrlEnter" FontSize="30" Background="LightSalmon"/>

        </DockPanel>

        <DockPanel Grid.Row="1" LastChildFill="True">

            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="75*"/>
                    <RowDefinition Height="25*"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Name="rawHtmlTextBox" FontSize="10" Background="AntiqueWhite" MinHeight="200" Text="Raw html" VerticalScrollBarVisibility="Auto" />
                <TextBox Grid.Row="1" Name="broadcastRecordTextBox" FontSize="10" Background="Beige" Text="First broadcast record"/>

            </Grid>

        </DockPanel>

    </Grid>
</Window>
