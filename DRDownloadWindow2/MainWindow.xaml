<Window x:Class="DRDownloadWindow2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DRDownloadWindow2.ViewModels"
        mc:Ignorable="d"
        Background="PeachPuff" 
        Height="800" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="False"
        Closing="OnWindowClosing"
        MouseLeftButtonDown="OnLeftMouseButtonDown"
        d:DataContext="{d:DesignInstance local:BroadcastViewModel, IsDesignTimeCreatable=False}">
    <Border Background="BlanchedAlmond" CornerRadius="30" Margin="20" Padding="40">

        <Border.Resources>
            <ControlTemplate x:Key="MM_BTN_TEMPLATE" TargetType="{x:Type Button}">

                <ControlTemplate.Resources>
                    <Brush x:Key="PeachPuffDark">#ffd7b9</Brush>
                    <Color x:Key="PeachPuff">#ffdab9</Color>
                    <Brush x:Key="PeachPuffLight">#ffddb9</Brush>
                </ControlTemplate.Resources>

                <!-- Visual tree -->
                <Grid Width="100" Height="100" Margin="10">
                    <Rectangle x:Name="MM_BTN_COLOR" RadiusX="20" RadiusY="20">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="{StaticResource ResourceKey=PeachPuff}"></SolidColorBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Viewbox>
                        <ContentPresenter Content="{TemplateBinding Content}" Margin="20">
                        </ContentPresenter>
                    </Viewbox>
                </Grid>
                <!-- Behaviour -->
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="MM_BTN_COLOR" Property="Fill" Value="{StaticResource ResourceKey=PeachPuffLight}"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <!-- Grow -->
                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"></ScaleTransform>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"></Setter>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="MM_BTN_COLOR" Property="Fill" Value="{StaticResource ResourceKey=PeachPuffDark}"/>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <!-- Shrink -->
                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"></ScaleTransform>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"></Setter>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Border.Resources>

        <DockPanel LastChildFill="False">
            <Image DockPanel.Dock="Top" Width="200" Margin="0,0,0,50" Source="C:\Users\micha\source\repos\MilkKB\DRDownloadWindow2\Ressources\Images\dr.png" />

            <StackPanel DockPanel.Dock="Top" Orientation="Vertical">
                <TextBox Text="{Binding Path=Title}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="30" IsReadOnly="True" FontWeight="Bold"></TextBox>
                <Separator Background="Gray"/>
                <TextBox Text="{Binding Path=SendDateAndDuration}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="20" IsReadOnly="True"></TextBox>
                <TextBlock Text="{Binding Path=Description}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" FontSize="20" TextWrapping="Wrap"></TextBlock>
                <TextBox Text="{Binding Path=Episode}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="20" IsReadOnly="True"></TextBox>
                <TextBox Text="{Binding Path=Channel}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="20" IsReadOnly="True"></TextBox>
                <TextBox Text="{Binding Path=Genre}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="20" IsReadOnly="True"></TextBox>
                <Expander Margin="0,30,0,0" FontFamily="Reem Kufi" Background="BlanchedAlmond" FontSize="20" Foreground="Gray" HorizontalAlignment="Stretch" Header="Tekniske detaljer" ExpandDirection="Down" IsExpanded="False">
                    <StackPanel Margin="0,10,0,0">
                        <TextBox Text="{Binding Path=UniqueId}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=EntryId}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=MediaType}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=Url}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=DownloadFolder}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=Mp3File}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=M3uFile}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=Mp4File}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                        <TextBox Text="{Binding Path=LogFile}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="Gray" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                    </StackPanel>
                </Expander>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical">
                <StatusBar Background="BlanchedAlmond" Foreground="Gray">
                    <StatusBarItem FontFamily="Reem Kufi">
                        <TextBox Text="{Binding Path=StatusBar}" FontFamily="Reem Kufi" Background="BlanchedAlmond" Foreground="{Binding Path=StatusBarColor}" BorderThickness="0" FontSize="10" IsReadOnly="True"></TextBox>
                    </StatusBarItem>
                    <!--<StatusBarItem Width="300" HorizontalAlignment="Right" HorizontalContentAlignment="Stretch">
                        <ProgressBar Value="{Binding Path=ProgressBar}" BorderThickness="0" Height="1" Foreground="{Binding Path=ProgressBarColor}" Background="BlanchedAlmond" Minimum="0" Maximum="100"/>
                    </StatusBarItem>-->
                </StatusBar>
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <Button Template="{StaticResource MM_BTN_TEMPLATE}" Command="{Binding CopyCommand}">
                    <Image Source="C:\Users\micha\source\repos\MilkKB\DRDownloadWindow2\Ressources\Images\copy.png"/>
                </Button>

                <Button Template="{StaticResource MM_BTN_TEMPLATE}" Command="{Binding DownloadCommand}">
                    <Image Source="C:\Users\micha\source\repos\MilkKB\DRDownloadWindow2\Ressources\Images\download.png"/>
                </Button>

                <ProgressBar Width="100" Height="100" Template="{StaticResource MM_PROGRESS_TEMPLATE}" Value="{Binding Path=ProgressBar}"/>

                <Button Template="{StaticResource MM_BTN_TEMPLATE}" Click="OnBtnClose">
                    <Image Source="C:\Users\micha\source\repos\MilkKB\DRDownloadWindow2\Ressources\Images\close.png"/>
                </Button>

            </StackPanel>

        </DockPanel>

    </Border>
</Window>
