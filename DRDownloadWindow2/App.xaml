<Application x:Class="DRDownloadWindow2.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DRDownloadWindow2"
             xmlns:utilities="clr-namespace:DRDownloadWindow2.Utilities"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <ControlTemplate x:Key="MM_PROGRESS_0_TO_100_PCT_TEMPLATE" TargetType="{x:Type ProgressBar}">

            <!-- Ressources -->
            <!-- https://htmlcolorcodes.com/colors/shades-of-orange/ -->
            <ControlTemplate.Resources>
                <Brush x:Key="ProgressColor">#FFF5EE</Brush>
                <Brush x:Key="TextColor">Gray</Brush>

                <utilities:ValueToPointConverter x:Key="pointConverter"/>
                <utilities:ValueToIsLargeArcConverter x:Key="arcConverter"/>
                <utilities:ValueToPercentageConverter x:Key="pctConverter"/>
            </ControlTemplate.Resources>

            <!-- Visual tree -->
            <Viewbox>
                <Grid Width="100" Height="100">
                    <Path Fill="{StaticResource ResourceKey=ProgressColor}">
                        <Path.Data>
                            <PathGeometry>
                                <PathGeometry.Figures>
                                    <PathFigureCollection>
                                        <PathFigure StartPoint="50,0" IsClosed="True">
                                            <PathFigure.Segments>
                                                <PathSegmentCollection>
                                                    <ArcSegment Size="50,50" SweepDirection="Clockwise" RotationAngle="-90">
                                                        <!--Point="79.38927,90.45085"-->
                                                        <ArcSegment.Point>
                                                            <MultiBinding Converter="{StaticResource pointConverter}">
                                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                                            </MultiBinding>
                                                        </ArcSegment.Point>
                                                        <ArcSegment.IsLargeArc>
                                                            <MultiBinding Converter="{StaticResource arcConverter}">
                                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                                            </MultiBinding>
                                                        </ArcSegment.IsLargeArc>
                                                    </ArcSegment>
                                                    <LineSegment Point="50,50"/>
                                                </PathSegmentCollection>
                                            </PathFigure.Segments>
                                        </PathFigure>
                                    </PathFigureCollection>
                                </PathGeometry.Figures>
                            </PathGeometry>
                        </Path.Data>
                    </Path>
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Reem Kufi" Foreground="{StaticResource ResourceKey=TextColor}" FontSize="20">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource pctConverter}">
                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </Viewbox>
        </ControlTemplate>

    </Application.Resources>

</Application>
